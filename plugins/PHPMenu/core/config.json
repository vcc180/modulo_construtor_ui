{
    "name": "plugin/phpmenu/",
    "description": "Gerar menu interativo",
    "type": "library",
    "authors": [
        {
            "name": "Vinícius Cordeiro Carvalho",
            "email": "vinicius_cproducoes@hotmail.com"
        }
